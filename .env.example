# gpix environment variables.
# Copy this file to .env and fill in the values you need.
#
# Only the credentials for the components you actually run are required:
#   - Web UI needs GP_AUTH_DATA
#   - Telegram bot needs GP_AUTH_DATA + TG_*

# ---- Google Photos auth ----
# Scraped from the Google Photos Android app — see README.
# Format: androidId=...&app=com.google.android.apps.photos&...&Token=aas_et/...
GP_AUTH_DATA=

# ---- Telegram bot (only if running `gpix -mode bot` or `gpix -mode all`) ----
# Token from @BotFather
TG_BOT_TOKEN=
# api_id + api_hash from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
# Your own Telegram user id (DM @userinfobot to find it).
# Only this user's commands are honored.
TG_OWNER_ID=

# ---- Optional ----
TG_SESSION_FILE=gpixbot.session
TG_TEMP_DIR=
TG_MAX_CONCURRENT=2

# Proxy for the Telegram client only (Google Photos API calls go direct).
# Supported schemes: socks5, socks4, http, mtproxy.
# Examples:
#   TG_PROXY=socks5://user:pass@127.0.0.1:1080
#   TG_PROXY=socks5://127.0.0.1:1080
#   TG_PROXY=http://user:pass@proxy.example.com:3128
#   TG_PROXY=mtproxy://<hex-secret>@proxy.example.com:443
TG_PROXY=

# ---- Encryption (non-media files only) ----
# When set, the web UI's Encrypt checkbox uses this by default and the bot's
# /upload / /get commands fall back to it when no inline encrypt:/decrypt:
# modifier is given. Per-file passphrases override this.
GPIX_ENC_PASSPHRASE=
